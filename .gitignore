# ─── OS / editor ─────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# ─── Cursor / local agent ────────────────────────────────────
.cursor/
.cursorignore

# ─── Dependencies ────────────────────────────────────────────
node_modules/
**/node_modules/

# ─── Env & secrets (never commit) ────────────────────────────
.env
.env.*
!.env.example
!**/.env.example
*.pem
*firebase-adminsdk*.json
**/serviceAccount*.json
credentials.json

# ─── Build / cache outputs ───────────────────────────────────
dist/
dist-ssr/
build/
.next/
out/
.cache/
coverage/
*.tsbuildinfo
.turbo/

# ─── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Backend uploads (keep folder, ignore files) ─────────────
backend/uploads/**
!backend/uploads/.gitkeep

# ─── Misc ────────────────────────────────────────────────────
*.local
.vercel
.netlify
tmp/
temp/
