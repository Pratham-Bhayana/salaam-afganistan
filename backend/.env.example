NODE_ENV=development
PORT=5000

# MongoDB — local or Atlas
MONGODB_URI=mongodb://127.0.0.1:27017/salaam_afghanistan
# MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER/salaam_afghanistan?retryWrites=true&w=majority

# JWT (required)
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_REFRESH_DAYS=7

# Seeded super admin
SEED_ADMIN_EMAIL=admin@salaam.local
SEED_ADMIN_PASSWORD=ChangeMeNow!123

# Seeded embassy admin (DXB)
SEED_EMBASSY_EMAIL=embassy.admin@salaam.local
SEED_EMBASSY_PASSWORD=ChangeMeNow!123

# SMTP (optional — JSON transport used when unset)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
EMAIL_FROM=Salaam Afghanistan <noreply@salaam.local>

# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_PER_MIN=300

# Firebase Auth for Website
# Client config: website/.env (NEXT_PUBLIC_FIREBASE_*)
# FIREBASE_AUTH_MODE=dev|live|disabled
FIREBASE_AUTH_MODE=dev
FIREBASE_PROJECT_ID=salaam-afganistan
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
