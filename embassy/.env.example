# Copy to .env.local for local development.
# On Vercel: Project Settings → Environment Variables (Production / Preview / Development).

# Backend API origin — no trailing slash.
VITE_API_BASE_URL=http://localhost:5000
# Production example:
# VITE_API_BASE_URL=https://api.yourdomain.com

# Backend must include this panel's deployed origin in CORS_ORIGINS (backend/.env), e.g.:
# CORS_ORIGINS=https://admin.yourdomain.com,https://embassy.yourdomain.com,https://yourdomain.com

# Optional — prefill login form in local dev only (do not set in production)
# VITE_EMBASSY_EMAIL=
# VITE_EMBASSY_PASSWORD=
